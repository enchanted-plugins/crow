{
  "description": "Hornet decision-gate: advisory review after file writes based on trust scores",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use/gate-change.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
